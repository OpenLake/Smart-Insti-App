# Backend API URL
# For Android Emulator: http://10.0.2.2:8000
# For iOS Simulator: http://localhost:8000
# For Real Device: http://<YOUR_PC_IP>:8000
API_URL=http://localhost:8000

# Socket.io URL (Usually same host as API, but without path)
# For Android Emulator: http://10.0.2.2:8000
# For Real Device: http://<YOUR_PC_IP>:8000
SOCKET_URL=http://localhost:8000

# Student Database API (CoSA)
STUDENT_DB_API_URL=https://student-database-cosa-jztd.onrender.com

# Hub API URL (OpenLake Hub proxy)
HUB_API_URL=https://hub.openlake.in/api/v1

# Supabase Configuration
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY